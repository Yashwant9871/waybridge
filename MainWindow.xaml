<Window x:Class="WaybridgeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Weighbridge System" Height="820" Width="1200" Background="#F5F7FA"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C2C2C" CornerRadius="8" Padding="12" Margin="0,0,0,16">
            <DockPanel>
                <Image Source="Assets/logo.png" Height="50" Width="120" Stretch="Uniform" DockPanel.Dock="Left" Margin="0,0,16,0"/>
                <TextBlock Text="Weighbridge System" Foreground="White" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Connection" FontWeight="Bold" FontSize="16" Foreground="#2C2C2C"/>
                    <ComboBox ItemsSource="{Binding ComPorts}" SelectedItem="{Binding SelectedComPort}" Margin="0,8,0,0" MinHeight="32"/>
                    <Button Content="Connect" Command="{Binding ConnectCommand}" Margin="0,8,0,0" MinHeight="34" Background="#E31E24" Foreground="White" FontWeight="SemiBold"/>
                    <TextBlock Text="Status:" Margin="0,8,0,0" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="#E31E24"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="8,0,8,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Live Weight" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Foreground="#2C2C2C"/>
                    <TextBlock Text="{Binding WeightDisplay}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="#2C2C2C"/>
                    <TextBlock Text="{Binding IsWeightStable, StringFormat=Stable: {0}}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Camera" FontWeight="Bold" FontSize="16" Foreground="#2C2C2C"/>
                    <ComboBox ItemsSource="{Binding Cameras}" SelectedItem="{Binding SelectedCamera}" Margin="0,8,0,0" MinHeight="32"/>
                    <TextBlock Text="{Binding CameraStatus}" Margin="0,8,0,0" Foreground="#2C2C2C"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Refresh" Command="{Binding RefreshCamerasCommand}" MinHeight="34" Width="90" Background="#F0F0F0" Foreground="#2C2C2C"/>
                        <Button Content="Start Camera" Command="{Binding StartCameraCommand}" MinHeight="34" Width="110" Margin="8,0,0,0" Background="#2C2C2C" Foreground="White"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Camera Preview" FontWeight="Bold" FontSize="16" Foreground="#2C2C2C"/>
                    <Border BorderBrush="#CCCCCC" BorderThickness="1" Height="280" Margin="0,8,0,0">
                        <Image Source="{Binding CameraFrame}" Stretch="Uniform"/>
                    </Border>
                    <Button Content="Capture Image" Command="{Binding CaptureCommand}" Margin="0,10,0,0" MinHeight="36" Background="#E31E24" Foreground="White" FontWeight="SemiBold" Width="140"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="12" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Record Details" FontWeight="Bold" FontSize="16" Foreground="#2C2C2C"/>
                    <TextBlock Text="Application No" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding ApplicationNo, UpdateSourceTrigger=PropertyChanged}" MinHeight="32"/>
                    <TextBlock Text="Vehicle No" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding VehicleNo, UpdateSourceTrigger=PropertyChanged}" MinHeight="32"/>
                    <TextBlock Text="Item No" Margin="0,8,0,2"/>
                    <TextBox Text="{Binding ItemNo, UpdateSourceTrigger=PropertyChanged}" MinHeight="32"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="White" CornerRadius="8" Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reset" Command="{Binding ResetCommand}" Width="120" MinHeight="38" Margin="0,0,8,0" Background="#2C2C2C" Foreground="White"/>
                <Button Content="Submit" Command="{Binding SubmitCommand}" Width="120" MinHeight="38" Background="#E31E24" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
